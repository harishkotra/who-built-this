# GitHub API token (required for higher rate limits)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Ethereum private key for onchain operations (without 0x prefix)
# Only needed for --publish and vouch commands
# The app defaults to Intuition Testnet (chain 13579)
PRIVATE_KEY=your_private_key_without_0x_prefix

# Intuition RPC URL (optional, defaults to Intuition Testnet)
INTUITION_RPC_URL=https://testnet.rpc.intuition.systems/http
